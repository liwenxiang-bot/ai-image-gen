# OpenAI API Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com

# Database (MySQL)
# 本地开发: mysql://root@127.0.0.1:3306/ai_image_gen_dev
# 生产环境: mysql://用户名:密码@<RDS 内网地址>:3306/ai_image_gen_prod
DATABASE_URL=mysql://root@127.0.0.1:3306/ai_image_gen_dev

# Redis（存验证码和会话）
# 本地开发: redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# WeChat 公众号配置
# 在 公众号后台 → 设置与开发 → 基本配置 → 服务器配置 中设置
WECHAT_TOKEN=your-random-token-string
WECHAT_APPID=
WECHAT_APP_SECRET=

# 公众号展示信息（NEXT_PUBLIC_* 会暴露到前端）
NEXT_PUBLIC_WECHAT_ACCOUNT_NAME=玖亿AI
# 二维码图片地址，留空默认使用 /public/wechat-qr.png
NEXT_PUBLIC_WECHAT_QRCODE_URL=/wechat-qr.png

# 图片云存储 —— STORAGE_PROVIDER=r2 (默认) 或 oss
STORAGE_PROVIDER=r2

# Cloudflare R2（S3 兼容，免费 10GB + 出网 0 费用）
# Bucket 必须开启 Public Access；填 R2_PUBLIC_BASE_URL 即可
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
# 可选：直接指定 endpoint 覆盖默认 https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
# R2_ENDPOINT=

# 阿里云 OSS（备选，STORAGE_PROVIDER=oss 时使用）
# Bucket 必须配为公共读
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=oss-cn-hangzhou
OSS_PUBLIC_BASE_URL=

# 易支付（彩虹/派坊系，购买积分）
EPAY_API_URL=https://你的易支付域名
EPAY_PID=
EPAY_KEY=
EPAY_NOTIFY_URL=http://127.0.0.1:3000/api/pay/notify
EPAY_RETURN_URL=http://127.0.0.1:3000/?pay=done
# 支付方式：wxpay / alipay，留空让收银台让用户自选
EPAY_PAY_TYPE=
