# =================================================================
#  生产环境配置（注意：是 .env，不是 .env.local）
#  cp .env.production.template .env  然后逐项填写
# =================================================================

NODE_ENV=production

# -- OpenAI 兼容端点 ------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.9e.lv

# -- 数据库（阿里云 RDS 生产库）-------------------------------------
# 推荐：在 RDS 上专门建一个 ai_image_gen_prod 库，单独的账号
# 密码里有 @ # 等特殊字符必须 URL 编码（@ → %40）
DATABASE_URL=mysql://prod_user:secret@rm-xxx.mysql.rds.aliyuncs.com:3306/ai_image_gen_prod

# -- Redis（本机）---------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379

# -- 微信公众号 -----------------------------------------------------
WECHAT_TOKEN=
WECHAT_APPID=
WECHAT_APP_SECRET=

# 前端可见
NEXT_PUBLIC_WECHAT_ACCOUNT_NAME=玖亿AI
NEXT_PUBLIC_WECHAT_QRCODE_URL=/wechat-qr.png

# -- 对象存储（Cloudflare R2）---------------------------------------
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=https://cdn.image2.one

# -- Worker --------------------------------------------------------
# 同时并发处理的任务数。注意 OpenAI rate limit。
WORKER_CONCURRENCY=4
