generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "mysql"
}

model User {
  id           String        @id @default(cuid())
  openid       String        @unique @db.VarChar(64)
  nickname     String?       @db.VarChar(64)
  credits      Int           @default(0) // 永久积分余额
  createdAt    DateTime      @default(now())
  images       Image[]
  jobs         Job[]
  orders       Order[]

  @@map("users")
}

model Image {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ossKey        String   @db.VarChar(255)
  prompt        String   @db.Text
  revisedPrompt String?  @db.Text
  mode          String   @db.VarChar(32)
  size          String   @db.VarChar(16)
  quality       String   @db.VarChar(16)
  isPublic      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([isPublic, createdAt])
  @@map("images")
}

model Job {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       String    @db.VarChar(16) // queued / running / done / failed / cancelled
  prompt       String    @db.Text
  mode         String    @db.VarChar(32)
  size         String    @db.VarChar(16)
  quality      String    @db.VarChar(16)
  inputKeys    Json?
  imageId      String?
  errorMessage String?   @db.Text
  cost         Int       @default(0) // 本次扣减的积分，用于失败退还
  refunded     Boolean   @default(false) // 失败是否已退还（幂等标记）
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([status])
  @@map("jobs")
}

/// 易支付订单（彩虹/派坊系）。一笔订单对应一次积分购买。
model Order {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  outTradeNo  String    @unique @db.VarChar(64) // 传给易支付的商户订单号
  tradeNo     String?   @db.VarChar(64) // 易支付返回的平台订单号
  packageId   String    @db.VarChar(32) // 套餐档位 id
  amount      String    @db.VarChar(16) // 金额（元），字符串避免浮点
  credits     Int // 该套餐到账的积分
  status      String    @default("pending") @db.VarChar(16) // pending / paid
  paidAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, createdAt])
  @@map("orders")
}
